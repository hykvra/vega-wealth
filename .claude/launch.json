{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "vega-wealth",
      "runtimeExecutable": "/opt/homebrew/bin/node",
      "runtimeArgs": ["-e", "const http=require('http'),fs=require('fs'),path=require('path'),mimes={'.html':'text/html','.css':'text/css','.js':'application/javascript','.jpg':'image/jpeg','.jpeg':'image/jpeg','.png':'image/png','.svg':'image/svg+xml','.ico':'image/x-icon','.webp':'image/webp','.xlsx':'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet'};http.createServer((req,res)=>{let u=decodeURIComponent(req.url.split('?')[0]);if(u.endsWith('/'))u+='index.html';let f=path.join(process.cwd(),u);if(!path.extname(f))f+='.html';fs.readFile(f,(e,d)=>{if(e){res.writeHead(404);res.end('Not found');return}res.writeHead(200,{'Content-Type':mimes[path.extname(f).toLowerCase()]||'application/octet-stream'});res.end(d)})}).listen(8080,()=>console.log('Server running on port 8080'))"],
      "port": 8080,
      "autoPort": true
    }
  ]
}
